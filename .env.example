# DeepSeek 密钥仅保存在服务端环境中
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选保护开关
CHAT_DISABLED=false

# Upstash Redis：未配置时仅在单实例内存中限流
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PRIVACY_HASH_SALT=
RATE_LIMIT_PER_MINUTE=5
SESSION_QUESTION_LIMIT=20
DAILY_REQUEST_LIMIT=200
DAILY_TOKEN_LIMIT=300000
TOKEN_RESERVATION=1500

# Neon Postgres：未配置时匿名埋点静默关闭
DATABASE_URL=
CRON_SECRET=

# Vercel Blob：上传脚本使用 Token，运行时只读取公开 PDF 地址
BLOB_READ_WRITE_TOKEN=
RESUME_BLOB_URL=
