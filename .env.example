# DeepSeek 密钥仅保存在服务端环境中
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选保护开关
CHAT_DISABLED=false

# Upstash Redis：Vercel Marketplace 默认注入 KV_REST_API_*；未配置时仅在单实例内存中限流
KV_REST_API_URL=
KV_REST_API_TOKEN=
PRIVACY_HASH_SALT=
RATE_LIMIT_PER_MINUTE=5
SESSION_QUESTION_LIMIT=20
DAILY_REQUEST_LIMIT=200
DAILY_TOKEN_LIMIT=300000
TOKEN_RESERVATION=1500

# Neon Postgres：未配置时匿名埋点静默关闭
DATABASE_URL=
CRON_SECRET=

# Vercel Blob：RESUME_ 前缀连接自动注入 Token，运行时只读取公开 PDF 地址
RESUME_READ_WRITE_TOKEN=
RESUME_STORE_ID=
RESUME_BLOB_URL=

# 仅本地使用：Obsidian 原文不进入部署环境，同步结果默认写入已忽略的 output/
OBSIDIAN_VAULT_PATH=
OBSIDIAN_SYNC_OUTPUT=output/obsidian-review.json
